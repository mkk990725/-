{
  "name": "football-analysis-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Explainable pre-match football analysis dashboard with a polling data service.",
  "scripts": {
    "start": "node server.js",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "api:dev": ".\\.conda\\football-agent\\python.exe -m uvicorn backend.app.main:app --host 127.0.0.1 --port 8000 --reload",
    "test:py": ".\\.conda\\football-agent\\python.exe -m pytest",
    "sync:once": "node server.js --once"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "echarts": "^5.6.0",
    "naive-ui": "^2.42.0",
    "vite": "^6.3.5",
    "vue": "^3.5.17"
  },
  "engines": {
    "node": ">=18"
  }
}
